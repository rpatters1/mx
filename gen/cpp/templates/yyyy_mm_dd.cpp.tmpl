bool {{ident}}::tryParse(std::string_view text, {{ident}} &out) noexcept
{
    const std::string_view t = trimWhitespace(text);
    if (t.size() != 10 || t[4] != '-' || t[7] != '-')
    {
        return false;
    }
    int year = 0;
    int month = 0;
