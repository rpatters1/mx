constexpr char kHex[] = "0123456789ABCDEF";

void appendByte(std::string &out, std::uint8_t value)
{
    out.push_back(kHex[value >> 4]);
    out.push_back(kHex[value & 0x0F]);
}

// The schema's pattern accepts digits and UPPERCASE hex letters only.
bool hexValue(char c, std::uint8_t &out) noexcept
{
    if (c >= '0' && c <= '9')
    {
        out = static_cast<std::uint8_t>(c - '0');
        return true;
    }
    if (c >= 'A' && c <= 'F')
    {
        out = static_cast<std::uint8_t>(c - 'A' + 10);
        return true;
    }
    return false;
}

bool parseByte(std::string_view text, std::size_t offset, std::uint8_t &out) noexcept
{
    std::uint8_t hi = 0;
    std::uint8_t lo = 0;
    if (!hexValue(text[offset], hi) || !hexValue(text[offset + 1], lo))
    {
        return false;
    }
    out = static_cast<std::uint8_t>((hi << 4) | lo);
    return true;
}

