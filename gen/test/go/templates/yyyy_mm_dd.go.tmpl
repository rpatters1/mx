// component returns the i-th dash-separated field of the date as an int,
// with the leniency the rest of the model applies to numbers: anything
// unparseable is 0. A leading minus sign (a BCE year) binds to the first
// component.
func (v {{ident}}) component(i int) int {
	s := string(v)
	negativeYear := strings.HasPrefix(s, "-")
	if negativeYear {
		s = s[1:]
	}
	parts := strings.SplitN(s, "-", 3)
	if i >= len(parts) {
		return 0
	}
	n, err := strconv.Atoi(strings.TrimSpace(parts[i]))
	if err != nil {
		return 0
	}
	if i == 0 && negativeYear {
		return -n
	}
	return n
}

