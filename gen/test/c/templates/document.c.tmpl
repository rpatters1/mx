    if (!root) {
        mx_error_set("document has no root element");
        return NULL;
    }
    MxDocument *d = calloc(1, sizeof(*d));
    if (!d)
        abort();
    size_t nscount = 0;
    for (xmlNsPtr ns = root->nsDef; ns; ns = ns->next)
        nscount++;
    if (nscount) {
        d->namespaces = calloc(nscount, sizeof(*d->namespaces));
        if (!d->namespaces)
            abort();
        for (xmlNsPtr ns = root->nsDef; ns; ns = ns->next) {
            MxNamespace *slot = &d->namespaces[d->namespaces_count++];
            slot->prefix = ns->prefix ? mx_strdup((const char *)ns->prefix) : NULL;
            slot->href = mx_strdup((const char *)ns->href);
