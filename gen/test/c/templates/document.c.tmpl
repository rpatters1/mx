        if (!d->{{name.snake}}) {
            mx_document_free(d);
            return NULL;
        }
{{/roots}}
    } else {
        mx_error_set("unknown root element <%s>", tag);
        mx_document_free(d);
        return NULL;
    }
    return d;
}

