{
    "permissions": {
        "allow": [
            "Agent",
            "Edit",
            "WebSearch",
            "WebFetch",
            "Write",
            "Read",
            "Bash"
        ]
    },
    "hooks":
    {
        "SessionStart":
        [
            {
                "hooks":
                [
                    {
